# OpenRouter API Key (free tier available at https://openrouter.ai)
# Used for AI-powered recipe parsing from OCR text
VITE_OPENROUTER_KEY=your_openrouter_api_key_here

# ============================================================================
# GITHUB MODELS VERIFICATION (FREE - RECOMMENDED)
# ============================================================================
# GitHub Models provides free AI-powered recipe verification
# Uses GPT-4o mini to validate and improve imported recipe data
#
# To enable verification (recommended):
# 1. Get a free GitHub token at https://github.com/settings/tokens
# 2. Select scope: read:user
# 3. Add to Supabase: supabase secrets set GITHUB_MODELS_TOKEN=your_token
#
# Note: This is a Supabase Edge Function secret, not a local .env variable
# See SETUP_GITHUB_TOKEN.md for detailed instructions
#
# GITHUB_MODELS_TOKEN=your_github_token_here (set via Supabase CLI or Dashboard)

# ============================================================================
# FIRECRAWL INTEGRATION (DISABLED BY DEFAULT - NO COST)
# ============================================================================
# Firecrawl is a paid service for browser-based scraping
# It is DISABLED by default to ensure you never incur unexpected costs
#
# To enable Firecrawl (only if you want to use it):
# 1. Get a free API key from https://firecrawl.dev (500 requests/month free)
# 2. Set FIRECRAWL_ENABLED=true
# 3. Set FIRECRAWL_API_KEY=your_api_key
#
# FIRECRAWL_ENABLED=false
# FIRECRAWL_API_KEY=your_firecrawl_api_key_here